clock {
     timezone EST+5EDT;
  timestamp '2010-06-01 00:00:00';
  stoptime '2010-06-03 00:00:00';
}
#set profiler=1
module tape;
module powerflow{
     solver_method NR;
      default_maximum_voltage_error 1e-6;
};
#ifdef WANT_VI_DUMP
#endif
module climate;
module generators;
module connection;
module residential {
  implicit_enduses NONE;
};
#include "../../../../support/schedules/appliance_schedules.glm";
#include "../../../../support/schedules/water_and_setpoint_schedule_v5.glm";
#include "../../../../support/schedules/commercial_schedules.glm";
#set minimum_timestep=15;
#set relax_naming_rules=1;
#set warn=0;
object metrics_collector_writer {
  interval 300;
  interim 43200;
  filename ${METRICS_FILE};
  // filename R2-12.47-1_processed_metrics.json;
};
object climate {
  name localWeather;
  // tmyfile "../../../../support/weather/AZ-Tucson_International_Ap.tmy3";
  // agent name weather
  interpolate QUADRATIC;
  latitude 30.0;
  longitude -110.0;
  // altitude 0.0;
  tz_meridian 0.0;
};
// default IEEE 1547-2018 settings for Category B
#define INV_VBASE=240.0
#define INV_V1=0.92
#define INV_V2=0.98
#define INV_V3=1.02
#define INV_V4=1.08
#define INV_Q1=0.44
#define INV_Q2=0.00
#define INV_Q3=0.00
#define INV_Q4=-0.44
#define INV_VIN=200.0
#define INV_IIN=32.5
#define INV_VVLOCKOUT=300.0
#define INV_VW_V1=1.05 // 1.05833
#define INV_VW_V2=1.10
#define INV_VW_P1=1.0
#define INV_VW_P2=0.0
#ifdef WANT_VI_DUMP
object voltdump {
  filename Voltage_Dump_R2-12.47-1_processed.csv;
  mode polar;
}
object currdump {
  filename Current_Dump_R2-12.47-1_processed.csv;
  mode polar;
}
#endif // &&& end of common section for combining TESP cases
// solar inverter mode on this feeder
#define INVERTER_MODE=CONSTANT_PF
